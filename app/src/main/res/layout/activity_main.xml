<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/latar_gelap"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔐 KriptoApp"
            android:textSize="28sp"
            android:textColor="@color/teks_utama"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enkripsi &amp; Dekripsi Teks"
            android:textSize="13sp"
            android:textColor="@color/teks_sekunder"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/kartu_latar"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/labelMetode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pilih Metode Kriptografi"
                    android:textSize="12sp"
                    android:textColor="@color/teks_sekunder"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerMetode"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:popupBackground="@color/kartu_latar" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/kartu_latar"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Teks Input"
                    android:textSize="12sp"
                    android:textColor="@color/teks_sekunder"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/inputTeks"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="@drawable/bg_input"
                    android:padding="14dp"
                    android:textColor="@color/teks_utama"
                    android:textColorHint="@color/teks_hint"
                    android:hint="Ketik pesan di sini..."
                    android:textSize="15sp"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minLines="4"
                    android:scrollbars="vertical" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:weightSum="3">

            <Button
                android:id="@+id/tombolEnkripsi"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1.2"
                android:text="🔒 Enkripsi"
                android:textSize="13sp"
                android:textColor="@color/teks_gelap"
                android:textStyle="bold"
                android:background="@drawable/bg_tombol_enkripsi"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/tombolDekripsi"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1.2"
                android:text="🔓 Dekripsi"
                android:textSize="13sp"
                android:textColor="@color/teks_utama"
                android:textStyle="bold"
                android:background="@drawable/bg_tombol_dekripsi"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/tombolHapus"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="0.6"
                android:text="🗑"
                android:textSize="16sp"
                android:background="@drawable/bg_tombol_hapus" />

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/kartu_hasil"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hasil"
                    android:textSize="12sp"
                    android:textColor="@color/aksen_hijau"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/outputTeks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="80dp"
                    android:text=""
                    android:hint="Hasil akan muncul di sini..."
                    android:textColorHint="@color/teks_hint"
                    android:textColor="@color/aksen_hijau"
                    android:textSize="15sp"
                    android:fontFamily="monospace"
                    android:gravity="top"
                    android:isScrollContainer="true"
                    android:scrollbars="vertical" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/kartu_info"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ℹ️  Keterangan Metode"
                    android:textSize="12sp"
                    android:textColor="@color/teks_sekunder"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Base64 — Enkoding biner ke teks\n• ROT13 — Geser 13 huruf (simetris)\n• Caesar — Geser 3 huruf (klasik)\n• Vigenere — Kunci: KUNCI\n• Atbash — Balik alfabet (A↔Z)"
                    android:textSize="12sp"
                    android:textColor="@color/teks_sekunder"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>