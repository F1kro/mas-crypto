<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#1A4D30"/>
            <corners android:radius="12dp"/>
            <stroke android:width="1.5dp" android:color="#2ECC71"/>
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#0D2018"/>
            <corners android:radius="12dp"/>
            <stroke android:width="1.5dp" android:color="#2ECC71"/>
        </shape>
    </item>
</selector>